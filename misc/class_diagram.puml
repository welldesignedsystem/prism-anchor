@startuml

package "Core" {

' ── Core orchestration ───────────────────────────────

abstract class WorkflowOrchestrator {
  + steps : List<StepBase>
  + run() : void
  + runLoop() : void
  + triggerStep(step : StepBase) : void
}
note right of WorkflowOrchestrator : Manages the execution of workflow steps

abstract class StepBase {
  # context : WorkflowContext
  + execute() : void
  # {abstract} setup() : void
  # {abstract} run() : void
  # {abstract} validate() : void
  # teardown() : void
}
note right of StepBase : Template method base class for all workflow steps

class WorkflowContext {
  + domain : String
  + queries : List<String>
  + results : Map<String, Object>
  + sharedState : Map<String, Object>
}
note right of WorkflowContext : Shared data container passed between steps

WorkflowOrchestrator "1" *-- "many" StepBase : steps
WorkflowOrchestrator --> WorkflowContext
StepBase --> WorkflowContext

note right
  Core orchestration framework providing:
  - WorkflowOrchestrator: Manages step execution
  - StepBase: Template method pattern for steps
  - WorkflowContext: Shared data container
end note

}

' ── Step 1 — Chain of Responsibility ────────────────

package "Setup (Step 1)" {

class SetupStep {
  - chain : ConfigHandler
  # run() : void
}
note right of SetupStep : Orchestrates configuration validation chain

abstract class ConfigHandler {
  # next : ConfigHandler
  + {abstract} handle(ctx : WorkflowContext) : void
  + setNext(h : ConfigHandler) : ConfigHandler
}
note right of ConfigHandler : Abstract base for configuration handlers

class DomainHandler
note right of DomainHandler : Normalizes and validates domain names

class QueryHandler
note right of QueryHandler : Validates and deduplicates search queries

class EngineHandler
note right of EngineHandler : Validates AI engine selection

class FrequencyHandler
note right of FrequencyHandler : Validates crawl frequency settings

SetupStep --|> StepBase
SetupStep --> ConfigHandler
ConfigHandler o-- ConfigHandler : next
DomainHandler --|> ConfigHandler
QueryHandler --|> ConfigHandler
EngineHandler --|> ConfigHandler
FrequencyHandler --|> ConfigHandler

note right
  Setup Step: Validates and configures project settings
  - Domain normalization and validation
  - Query deduplication and validation
  - AI engine selection
  - Crawl frequency configuration
  Uses Chain of Responsibility pattern
end note

}

' ── Step 2 — Chain of Responsibility + short-circuit ─

package "Audit (Step 2)" {

class AuditStep {
  - chain : AuditHandler
  # run() : void
}
note right of AuditStep : Orchestrates technical audit chain

abstract class AuditHandler {
  # next : AuditHandler
  + {abstract} handle(ctx : WorkflowContext) : Boolean
  + setNext(h : AuditHandler) : AuditHandler
}
note right of AuditHandler : Abstract base for audit handlers

class CrawlerAuditHandler
note right of CrawlerAuditHandler : Checks AI bot accessibility

class TechnicalSEOHandler
note right of TechnicalSEOHandler : Validates technical SEO elements

class ContentAuditHandler
note right of ContentAuditHandler : Analyzes content for AI optimization

AuditStep --|> StepBase
AuditStep --> AuditHandler
AuditHandler o-- AuditHandler : next
CrawlerAuditHandler --|> AuditHandler
TechnicalSEOHandler --|> AuditHandler
ContentAuditHandler --|> AuditHandler

note right
  Audit Step: Performs initial technical audits
  - CrawlerAuditHandler: Checks if AI bots can access site
  - TechnicalSEOHandler: Validates speed, sitemap, broken links
  - ContentAuditHandler: Analyzes content for AEO/GEO potential
  Uses Chain of Responsibility with short-circuiting
end note

}

' ── Step 3 — Observer ────────────────────────────────

package "Monitor (Step 3)" {

class MonitorStep {
  - trackers : List<VisibilityTracker>
  # run() : void
  + subscribe(t : VisibilityTracker) : void
  + notify(event : TrackingEvent) : void
}
note right of MonitorStep : Manages visibility tracking observers

interface VisibilityTracker {
  + onUpdate(event : TrackingEvent) : void
}
note right of VisibilityTracker : Interface for tracking components

class GEOTracker
note right of GEOTracker : Tracks AI search result citations

class AEOTracker
note right of AEOTracker : Tracks snippet and PAA ownership

class SEORankTracker
note right of SEORankTracker : Tracks organic search rankings

class VoiceSearchTracker
note right of VoiceSearchTracker : Tracks voice search answers

MonitorStep --|> StepBase
MonitorStep "1" o-- "many" VisibilityTracker
GEOTracker ..|> VisibilityTracker
AEOTracker ..|> VisibilityTracker
SEORankTracker ..|> VisibilityTracker
VoiceSearchTracker ..|> VisibilityTracker

note right
  Monitor Step: Tracks AI engine visibility continuously
  - GEOTracker: Monitors citations in AI search results
  - AEOTracker: Tracks snippet and PAA box ownership
  - SEORankTracker: Monitors organic search rankings
  - VoiceSearchTracker: Tracks spoken answer presence
  Uses Observer pattern for real-time updates
end note

}

' ── Step 4 — Composite ───────────────────────────────

package "Score (Step 4)" {

class ScoreStep {
  - root : ScoreComponent
  # run() : void
}
note right of ScoreStep : Orchestrates score computation

interface ScoreComponent {
  + compute(ctx : WorkflowContext) : ScoreResult
}
note right of ScoreComponent : Interface for score calculators

class CompositeScore {
  - children : List<ScoreComponent>
  + add(c : ScoreComponent) : void
  + compute(ctx : WorkflowContext) : ScoreResult
}
note right of CompositeScore : Composite score aggregator

class GEOScore
note right of GEOScore : Calculates citation frequency scores

class AEOScore
note right of AEOScore : Calculates snippet win rates

class SEOScore
note right of SEOScore : Evaluates organic ranking health

class CompetitorShareScore
note right of CompetitorShareScore : Compares competitor citations

ScoreStep --|> StepBase
ScoreStep --> ScoreComponent
CompositeScore ..|> ScoreComponent
CompositeScore "1" o-- "many" ScoreComponent : children
GEOScore ..|> ScoreComponent
AEOScore ..|> ScoreComponent
SEOScore ..|> ScoreComponent
CompetitorShareScore ..|> ScoreComponent

note right
  Score Step: Computes visibility scores and metrics
  - GEOScore: Calculates AI citation frequency (0-100)
  - AEOScore: Measures snippet/PAA box win rates
  - SEOScore: Evaluates organic ranking health
  - CompetitorShareScore: Compares citations vs competitors
  Uses Composite pattern for hierarchical scoring
end note

}

' ── Step 5 — Strategy (fan-out) ──────────────────────

package "Optimise (Step 5)" {

class OptimiseStep {
  - analyser : ContentAnalyser
  - strategies : List<OptimisationStrategy>
  # run() : void
}
note right of OptimiseStep : Orchestrates content optimization

interface OptimisationStrategy {
  + optimise(analysis : ContentAnalysis) : OptimisationResult
}
note right of OptimisationStrategy : Interface for optimization strategies

class ContentAnalyser
note right of ContentAnalyser : Analyzes content gaps

class BriefGeneratorStrategy
note right of BriefGeneratorStrategy : Generates content briefs

class FAQGeneratorStrategy
note right of FAQGeneratorStrategy : Generates FAQ content

class SchemaBuilderStrategy
note right of SchemaBuilderStrategy : Generates structured data

OptimiseStep --|> StepBase
OptimiseStep --> ContentAnalyser
OptimiseStep "1" o-- "many" OptimisationStrategy : strategies
BriefGeneratorStrategy ..|> OptimisationStrategy
FAQGeneratorStrategy ..|> OptimisationStrategy
SchemaBuilderStrategy ..|> OptimisationStrategy

note right
  Optimise Step: Generates content optimization suggestions
  - ContentAnalyser: Scores pages and identifies gaps
  - BriefGeneratorStrategy: Creates answer-first content briefs
  - FAQGeneratorStrategy: Builds Q&As from PAA data
  - SchemaBuilderStrategy: Generates JSON-LD markup
  Uses Strategy pattern with fan-out execution
end note

}

' ── Step 6 — Strategy (routing) ──────────────────────

package "Alert (Step 6)" {

class AlertStep {
  - router : AlertRouter
  # run() : void
}
note right of AlertStep : Orchestrates alert routing

class AlertRouter {
  + route(alert : Alert) : AlertStrategy
}
note right of AlertRouter : Routes alerts to strategies

interface AlertStrategy {
  + dispatch(alert : Alert) : void
}
note right of AlertStrategy : Interface for alert dispatch

class ImmediateAlertStrategy
note right of ImmediateAlertStrategy : Handles critical alerts

class DailyDigestStrategy
note right of DailyDigestStrategy : Handles daily summaries

class WeeklySummaryStrategy
note right of WeeklySummaryStrategy : Handles weekly reports

AlertStep --|> StepBase
AlertStep --> AlertRouter
AlertRouter --> AlertStrategy
ImmediateAlertStrategy ..|> AlertStrategy
DailyDigestStrategy ..|> AlertStrategy
WeeklySummaryStrategy ..|> AlertStrategy

note right
  Alert Step: Routes alerts based on severity and timing
  - ImmediateAlertStrategy: Critical alerts (Slack + Email)
  - DailyDigestStrategy: Moderate changes (Email)
  - WeeklySummaryStrategy: Positive trends (Email)
  Uses Strategy pattern with routing logic
end note

}

' ── Step 7 — Builder ─────────────────────────────────

package "Report (Step 7)" {

class ReportStep {
  - builder : ReportBuilder
  # run() : void
}
note right of ReportStep : Orchestrates report generation

interface ReportBuilder {
  + addClientReport() : ReportBuilder
  + addExecDashboard() : ReportBuilder
  + addExport(format : ExportFormat) : ReportBuilder
  + build() : Report
}
note right of ReportBuilder : Interface for report building

class WhiteLabelReportBuilder
note right of WhiteLabelReportBuilder : Creates branded reports

class Report
note right of Report : Report data container

enum ExportFormat {
  SHEETS
  LOOKER
  BIGQUERY
  API
}
note right of ExportFormat : Supported export formats

ReportStep --|> StepBase
ReportStep --> ReportBuilder
WhiteLabelReportBuilder ..|> ReportBuilder
ReportBuilder --> Report
ReportBuilder --> ExportFormat

note right
  Report Step: Generates comprehensive reports and exports
  - WhiteLabelReportBuilder: Creates branded client PDFs
  - Executive Dashboard: GEO/AEO/SEO scores overview
  - Export formats: Sheets, Looker Studio, BigQuery, API
  Uses Builder pattern for flexible report construction
end note

}

@enduml
